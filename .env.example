# StashBro server configuration
# Copy this file to .env and fill in the values.

# Required: secret token for API auth (min 16 chars recommended)
# Generate one: openssl rand -hex 32
AUTH_TOKEN=change-me-to-a-random-string

# Auth mode: "token" for self-host (default), "magic-link" for hosted
AUTH_MODE=token

# Port the server listens on (default 3000)
# PORT=3000
